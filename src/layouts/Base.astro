---
import "../styles/global.css";
import { site } from "../data/content";
import WhatsAppChat from "../components/WhatsAppChat";
import WaitlistModal from "../components/WaitlistModal.astro";


interface Props {
  title?: string;
  description?: string;
  ldExtra?: Record<string, unknown>[];
}

const {
  title = `${site.name} — ${site.tagline}`,
  description = site.description,
  ldExtra = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = `${Astro.site}og-image.png`;
const siteUrl = Astro.site?.href || "https://tiendapos-app.vercel.app/";

const ldWebSite = {
  "@type": "WebSite",
  name: site.name,
  url: siteUrl,
  description: site.description,
  image: `${Astro.site}og-image.png`,
  inLanguage: "es",
  potentialAction: {
    "@type": "SearchAction",
    target: { "@type": "EntryPoint", urlTemplate: `${siteUrl}?s={search_term_string}` },
    "query-input": "required name=search_term_string",
  },
};

const ldOrganization = {
  "@type": "Organization",
  name: site.name,
  url: siteUrl,
  description: site.description,
  logo: `${Astro.site}og-image.png`,
  image: `${Astro.site}og-image.png`,
  foundingDate: "2025",
  address: {
    "@type": "PostalAddress",
    streetAddress: site.direccion,
    addressLocality: "San Cristóbal",
    addressRegion: "Táchira",
    addressCountry: "VE",
  },
  vatID: site.rif,
  contactPoint: {
    "@type": "ContactPoint",
    telephone: site.whatsapp,
    contactType: "customer service",
    email: site.email,
    availableLanguage: ["Spanish"],
  },
  sameAs: [
    `https://wa.me/${site.whatsapp?.replace(/[^0-9]/g, "") || "584247253544"}`,
  ],
};

const ldSoftware = {
  "@type": "SoftwareApplication",
  name: site.name,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: site.description,
  applicationSuite: "TiendaPOS",
  countriesSupported: "VE,CO,MX,EC,AR,PE,CL,BO,UY",
  featureList: "Multi-tenant, Multi-moneda 15 divisas, IGTF automático, Control de inventario, Ventas al crédito, Cierre de caja multimoneda, Roles y permisos, Dashboard KPIs",
  screenshot: `${Astro.site}og-image.png`,
  offers: {
    "@type": "AggregateOffer",
    lowPrice: "0",
    highPrice: "45",
    priceCurrency: "USD",
    priceSpecification: {
      "@type": "UnitPriceSpecification",
      price: "45",
      priceCurrency: "USD",
      billingDuration: {
        "@type": "QuantitativeValue",
        value: "1",
        unitCode: "MON",
      },
      billingIncrement: {
        "@type": "QuantitativeValue",
        value: "1",
        unitCode: "MON",
      },
    },
  },
};

const ldBreadcrumb = {
  "@type": "BreadcrumbList",
  name: "Navegación",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: siteUrl },
  ],
};

const ldGraph = {
  "@context": "https://schema.org",
  "@graph": [ldWebSite, ldOrganization, ldSoftware, ldBreadcrumb, ...ldExtra],
};

const ldScript = `<script type="application/ld+json">${JSON.stringify(ldGraph)}</script>`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Fonts: Montserrat for headings, Inter for body -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Montserrat:wght@600;700;800;900&display=swap"
      rel="stylesheet"
      media="print" onload="this.media='all'"
    />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Montserrat:wght@600;700;800;900&display=swap" rel="stylesheet" /></noscript>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    <!-- SEO: canonical + Open Graph -->
    <link rel="canonical" href={canonical} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="es_VE" />
    <meta name="twitter:site" content="@tiendapos" />
    <meta name="twitter:creator" content="@tiendapos" />
    <meta name="robots" content="index, follow" />
    <link rel="alternate" href={canonical} hreflang="es" />

    <!-- JSON-LD Structured Data -->
    <Fragment set:html={ldScript} />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" crossorigin="use-credentials" href="/site.webmanifest" />
    <meta name="msapplication-TileColor" content="#0A0A0B" />

    <!-- Theme color -->
    <meta name="theme-color" content="#0A0A0B" />

  </head>
  <body class="antialiased">
    <!-- Scroll progress bar -->
    <div id="progress-bar" class="fixed top-0 left-0 z-[99] h-[3px] bg-amber shadow-lg shadow-amber/30" style="width: 0%; transition: width 80ms linear;"></div>

    <script>
      const bar = document.getElementById("progress-bar");
      if (bar) {
        window.addEventListener("scroll", () => {
          const h = document.documentElement.scrollHeight - window.innerHeight;
          bar.style.width = h > 0 ? `${(window.scrollY / h) * 100}%` : "0%";
        }, { passive: true });
      }
    </script>

    <slot />

    <!-- Back to top -->
    <button
      id="back-to-top"
      aria-label="Volver al inicio"
      class="fixed bottom-24 right-6 z-30 w-9 h-9 rounded-full bg-amber flex items-center justify-center text-zinc-900 hover:bg-amber-dark transition-all duration-300 opacity-0 invisible translate-y-2"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
    </button>
    <script>
      const backBtn = document.getElementById("back-to-top");
      if (backBtn) {
        window.addEventListener("scroll", () => {
          if (window.scrollY > 400) {
            backBtn.classList.remove("opacity-0", "invisible", "translate-y-2");
            backBtn.classList.add("opacity-100", "visible", "translate-y-0");
          } else {
            backBtn.classList.add("opacity-0", "invisible", "translate-y-2");
            backBtn.classList.remove("opacity-100", "visible", "translate-y-0");
          }
        }, { passive: true });
        backBtn.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    </script>

    <WhatsAppChat client:idle />
    <WaitlistModal client:idle />

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (!prefersReduced) {
        // Smooth scroll behavior
        document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
          anchor.addEventListener("click", function (e) {
            e.preventDefault();
            const target = document.querySelector(
              this.getAttribute("href") || ""
            );
            if (target) {
              target.scrollIntoView({ behavior: "smooth", block: "start" });
            }
          });
        });

        // Fade-up universal
        gsap.utils.toArray<HTMLElement>(".gsap-fade-up").forEach((el) => {
          const isCTA = el.closest("#cta");
          gsap.fromTo(
            el,
            { opacity: 0, y: isCTA ? 15 : 30 },
            {
              opacity: 1,
              y: 0,
              duration: isCTA ? 0.5 : 0.8,
              ease: "power2.out",
              scrollTrigger: {
                trigger: el,
                start: isCTA ? "top 92%" : "top 88%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Fade-in
        gsap.utils.toArray<HTMLElement>(".gsap-fade-in").forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0 },
            {
              opacity: 1,
              duration: 1,
              ease: "power2.out",
              scrollTrigger: {
                trigger: el,
                start: "top 90%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Scale-in
        gsap.utils.toArray<HTMLElement>(".gsap-scale-in").forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, scale: 0.92 },
            {
              opacity: 1,
              scale: 1,
              duration: 0.9,
              ease: "power3.out",
              scrollTrigger: {
                trigger: el,
                start: "top 85%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Slide-left
        gsap.utils.toArray<HTMLElement>(".gsap-slide-left").forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, x: -40 },
            {
              opacity: 1,
              x: 0,
              duration: 0.8,
              ease: "power3.out",
              scrollTrigger: {
                trigger: el,
                start: "top 88%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Slide-right
        gsap.utils.toArray<HTMLElement>(".gsap-slide-right").forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, x: 40 },
            {
              opacity: 1,
              x: 0,
              duration: 0.8,
              ease: "power3.out",
              scrollTrigger: {
                trigger: el,
                start: "top 88%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Blur-in
        gsap.utils.toArray<HTMLElement>(".gsap-blur-in").forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, filter: "blur(10px)" },
            {
              opacity: 1,
              filter: "blur(0px)",
              duration: 1,
              ease: "power2.out",
              scrollTrigger: {
                trigger: el,
                start: "top 85%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Stagger
        gsap.utils.toArray<HTMLElement>(".gsap-stagger").forEach((cont) => {
          const isCTA = cont.closest("#cta");
          const hijos = Array.from(cont.children) as HTMLElement[];
          gsap.fromTo(
            hijos,
            { opacity: 0, y: isCTA ? 12 : 24 },
            {
              opacity: 1,
              y: 0,
              duration: isCTA ? 0.4 : 0.7,
              ease: isCTA ? "power1.out" : "power3.out",
              stagger: isCTA ? 0.06 : 0.1,
              scrollTrigger: {
                trigger: cont,
                start: isCTA ? "top 92%" : "top 85%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Reveal-mask
        gsap.utils.toArray<HTMLElement>(".gsap-reveal-mask").forEach((el) => {
          gsap.fromTo(
            el,
            { clipPath: "inset(0 100% 0 0)" },
            {
              clipPath: "inset(0 0% 0 0)",
              duration: 1.2,
              ease: "power4.out",
              scrollTrigger: {
                trigger: el,
                start: "top 80%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Parallax
        gsap.utils.toArray<HTMLElement>("[data-parallax]").forEach((el) => {
          const speed = parseFloat(el.dataset.parallax || "0.3");
          gsap.to(el, {
            yPercent: -speed * 100,
            ease: "none",
            scrollTrigger: {
              trigger: el,
              start: "top bottom",
              end: "bottom top",
              scrub: true,
            },
          });
        });

        // Counter animation for numbers
        gsap.utils.toArray<HTMLElement>("[data-counter]").forEach((el) => {
          const target = parseInt(el.dataset.counter || "0");
          gsap.fromTo(
            el,
            { textContent: "0" },
            {
              textContent: String(target),
              duration: 2,
              ease: "power2.out",
              snap: { textContent: 1 },
              scrollTrigger: {
                trigger: el,
                start: "top 90%",
                toggleActions: "play none none none",
              },
            }
          );
        });
      } else {
        // Reduced motion
        document
          .querySelectorAll(
            ".gsap-fade-up, .gsap-fade-in, .gsap-reveal-mask, .gsap-scale-in, .gsap-slide-left, .gsap-slide-right, .gsap-blur-in, .gsap-stagger > *"
          )
          .forEach((el) => {
            (el as HTMLElement).style.opacity = "1";
            (el as HTMLElement).style.transform = "none";
            (el as HTMLElement).style.clipPath = "none";
            (el as HTMLElement).style.filter = "none";
          });
      }
    </script>
  </body>
</html>
