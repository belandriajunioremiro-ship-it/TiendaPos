---
import "../styles/global.css";
import { site } from "../data/content";
import WhatsAppChat from "../components/WhatsAppChat";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} — ${site.tagline}`,
  description = site.description,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = `${Astro.site}og-image.png`;

const ldWebSite = {
  "@type": "WebSite",
  name: site.name,
  url: Astro.site?.href || "https://tiendapos-app.vercel.app/",
};

const ldOrganization = {
  "@type": "Organization",
  name: site.name,
  url: Astro.site?.href || "https://tiendapos-app.vercel.app/",
  description: site.description,
  contactPoint: {
    "@type": "ContactPoint",
    telephone: site.whatsapp,
    contactType: "customer service",
    email: site.email,
  },
};

const ldSoftware = {
  "@type": "SoftwareApplication",
  name: site.name,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: site.description,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
};

const ldGraph = {
  "@context": "https://schema.org",
  "@graph": [ldWebSite, ldOrganization, ldSoftware],
};

const ldScript = `<script type="application/ld+json">${JSON.stringify(ldGraph)}</script>`;
---

<!doctype html>
<html lang="es-VE">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Fonts: Montserrat for headings, Inter for body -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Montserrat:wght@600;700;800;900&display=swap"
      rel="stylesheet"
      media="print" onload="this.media='all'"
    />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Montserrat:wght@600;700;800;900&display=swap" rel="stylesheet" /></noscript>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- SEO: canonical + Open Graph -->
    <link rel="canonical" href={canonical} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="es_VE" />
    <meta name="twitter:site" content="@tiendapos" />
    <meta name="twitter:creator" content="@tiendapos" />
    <meta name="robots" content="index, follow" />
    <link rel="alternate" href={canonical} hreflang="es-VE" />
    <link rel="alternate" href={canonical} hreflang="es" />

    <!-- JSON-LD Structured Data -->
    <Fragment set:html={ldScript} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Theme color -->
    <meta name="theme-color" content="#0A0A0B" />
  </head>
  <body class="antialiased">
    <slot />

    <WhatsAppChat client:load />

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (!prefersReduced) {
        // Smooth scroll behavior
        document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
          anchor.addEventListener("click", function (e) {
            e.preventDefault();
            const target = document.querySelector(
              this.getAttribute("href") || ""
            );
            if (target) {
              target.scrollIntoView({ behavior: "smooth", block: "start" });
            }
          });
        });

        // Fade-up universal
        gsap.utils.toArray<HTMLElement>(".gsap-fade-up").forEach((el) => {
          const isCTA = el.closest("#cta");
          gsap.fromTo(
            el,
            { opacity: 0, y: isCTA ? 15 : 30 },
            {
              opacity: 1,
              y: 0,
              duration: isCTA ? 0.5 : 0.8,
              ease: "power2.out",
              scrollTrigger: {
                trigger: el,
                start: isCTA ? "top 92%" : "top 88%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Fade-in
        gsap.utils.toArray<HTMLElement>(".gsap-fade-in").forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0 },
            {
              opacity: 1,
              duration: 1,
              ease: "power2.out",
              scrollTrigger: {
                trigger: el,
                start: "top 90%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Scale-in
        gsap.utils.toArray<HTMLElement>(".gsap-scale-in").forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, scale: 0.92 },
            {
              opacity: 1,
              scale: 1,
              duration: 0.9,
              ease: "power3.out",
              scrollTrigger: {
                trigger: el,
                start: "top 85%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Slide-left
        gsap.utils.toArray<HTMLElement>(".gsap-slide-left").forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, x: -40 },
            {
              opacity: 1,
              x: 0,
              duration: 0.8,
              ease: "power3.out",
              scrollTrigger: {
                trigger: el,
                start: "top 88%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Slide-right
        gsap.utils.toArray<HTMLElement>(".gsap-slide-right").forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, x: 40 },
            {
              opacity: 1,
              x: 0,
              duration: 0.8,
              ease: "power3.out",
              scrollTrigger: {
                trigger: el,
                start: "top 88%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Blur-in
        gsap.utils.toArray<HTMLElement>(".gsap-blur-in").forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, filter: "blur(10px)" },
            {
              opacity: 1,
              filter: "blur(0px)",
              duration: 1,
              ease: "power2.out",
              scrollTrigger: {
                trigger: el,
                start: "top 85%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Stagger
        gsap.utils.toArray<HTMLElement>(".gsap-stagger").forEach((cont) => {
          const isCTA = cont.closest("#cta");
          const hijos = Array.from(cont.children) as HTMLElement[];
          gsap.fromTo(
            hijos,
            { opacity: 0, y: isCTA ? 12 : 24 },
            {
              opacity: 1,
              y: 0,
              duration: isCTA ? 0.4 : 0.7,
              ease: isCTA ? "power1.out" : "power3.out",
              stagger: isCTA ? 0.06 : 0.1,
              scrollTrigger: {
                trigger: cont,
                start: isCTA ? "top 92%" : "top 85%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Reveal-mask
        gsap.utils.toArray<HTMLElement>(".gsap-reveal-mask").forEach((el) => {
          gsap.fromTo(
            el,
            { clipPath: "inset(0 100% 0 0)" },
            {
              clipPath: "inset(0 0% 0 0)",
              duration: 1.2,
              ease: "power4.out",
              scrollTrigger: {
                trigger: el,
                start: "top 80%",
                toggleActions: "play none none none",
              },
            }
          );
        });

        // Parallax
        gsap.utils.toArray<HTMLElement>("[data-parallax]").forEach((el) => {
          const speed = parseFloat(el.dataset.parallax || "0.3");
          gsap.to(el, {
            yPercent: -speed * 100,
            ease: "none",
            scrollTrigger: {
              trigger: el,
              start: "top bottom",
              end: "bottom top",
              scrub: true,
            },
          });
        });

        // Counter animation for numbers
        gsap.utils.toArray<HTMLElement>("[data-counter]").forEach((el) => {
          const target = parseInt(el.dataset.counter || "0");
          gsap.fromTo(
            el,
            { textContent: "0" },
            {
              textContent: String(target),
              duration: 2,
              ease: "power2.out",
              snap: { textContent: 1 },
              scrollTrigger: {
                trigger: el,
                start: "top 90%",
                toggleActions: "play none none none",
              },
            }
          );
        });
      } else {
        // Reduced motion
        document
          .querySelectorAll(
            ".gsap-fade-up, .gsap-fade-in, .gsap-reveal-mask, .gsap-scale-in, .gsap-slide-left, .gsap-slide-right, .gsap-blur-in, .gsap-stagger > *"
          )
          .forEach((el) => {
            (el as HTMLElement).style.opacity = "1";
            (el as HTMLElement).style.transform = "none";
            (el as HTMLElement).style.clipPath = "none";
            (el as HTMLElement).style.filter = "none";
          });
      }
    </script>
  </body>
</html>
