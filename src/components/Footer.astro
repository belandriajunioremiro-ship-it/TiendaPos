---
import { site } from "../data/content";
import { FileText, Shield, Scale } from "lucide-astro";
import { FaTiktok, FaInstagram } from "react-icons/fa";

const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden bg-dark-primary min-h-[400px] flex flex-col justify-between">
  <!-- Background -->
  <div class="absolute inset-0 grid-pattern opacity-20 pointer-events-none" />

  <!-- Giant watermark -->
  <div class="absolute inset-0 flex items-end justify-center pointer-events-none px-4 pb-6">
    <span
      class="font-display font-black text-[clamp(5rem,28vw,18rem)] text-zinc-900/35 select-none text-center leading-none"
      style="letter-spacing: -0.04em;"
    >
      TiendaPOS
    </span>
  </div>

  <div class="container-main relative py-16 lg:py-20">
    <div class="relative z-10 flex flex-col items-center text-center max-w-2xl mx-auto">
      <!-- Brand -->
      <div class="flex flex-col items-center gap-2 mb-5">
        <img src="/assets/TiendaPoslogo1.png" alt="TiendaPOS" width="300" height="300" class="h-28 w-auto" />
        <span class="font-display font-bold text-base text-zinc-100">
          TiendaPOS
        </span>
      </div>

      <p class="text-zinc-400 leading-relaxed max-w-lg">
        Sistema POS y punto de venta multi-país para farmacias, abastos y comercios en Latinoamérica. 9 países, multi-moneda e IGTF incluido.
      </p>

      <!-- Legal links -->
      <div class="mt-10 flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm">
        <a href="/privacidad" class="inline-flex items-center gap-1.5 text-zinc-500 hover:text-amber transition-colors duration-300">
          <FileText size={14} />
          Politica de privacidad
        </a>
        <a href="/terminos" class="inline-flex items-center gap-1.5 text-zinc-500 hover:text-amber transition-colors duration-300">
          <Shield size={14} />
          Terminos de servicio
        </a>
        <a href="/aviso-legal" class="inline-flex items-center gap-1.5 text-zinc-500 hover:text-amber transition-colors duration-300">
          <Scale size={14} />
          Aviso legal
        </a>
      </div>

      <!-- Social -->
      <div class="mt-8 flex gap-4">
        <a
          href="#"
          class="w-14 h-14 rounded-full bg-zinc-800/60 border-2 border-amber/30 flex items-center justify-center text-amber hover:bg-amber/20 hover:border-amber/60 hover:scale-110 shadow-lg shadow-amber/10 transition-all duration-300"
          aria-label="TikTok"
        >
          <FaTiktok size={24} />
        </a>
        <a
          href="#"
          class="w-14 h-14 rounded-full bg-zinc-800/60 border-2 border-amber/30 flex items-center justify-center text-amber hover:bg-amber/20 hover:border-amber/60 hover:scale-110 shadow-lg shadow-amber/10 transition-all duration-300"
          aria-label="Instagram"
        >
          <FaInstagram size={26} />
        </a>
      </div>
    </div>
  </div>
</footer>
