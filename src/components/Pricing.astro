---
import { planes } from "../data/content";
import { Check } from "lucide-astro";
import { waUrl } from "../data/whatsapp";
---

<section id="pricing" class="relative overflow-hidden py-20 lg:py-28 bg-dark-secondary">
  <!-- Background -->
  <div class="absolute inset-0 grid-pattern opacity-20 pointer-events-none" />
  <div class="absolute top-1/3 left-0 w-96 h-96 bg-amber/5 rounded-full blur-3xl pointer-events-none" />

  <div class="container-main relative">
    <div class="max-w-3xl mb-12">
      <h2 class="gsap-fade-up text-zinc-100">
        Un plan para cada realidad.<br />
        <span class="text-zinc-500">Desde emprender hasta escalar.</span>
      </h2>
    </div>

    <div class="gsap-stagger grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {planes.map((p, i) => (
        <div class={`relative p-6 lg:p-7 rounded-xl flex flex-col transition-all duration-300 ${
          p.destacado
            ? 'bg-zinc-900 border-2 border-amber/50 hover:border-amber shadow-lg shadow-amber/10'
            : 'bg-zinc-900/60 border border-zinc-800/60 hover:border-zinc-700'
        }`}>
          <!-- Corner badges -->
          <div class={`absolute top-0 left-0 px-3 py-1.5 rounded-tl-xl rounded-br-lg text-[11px] font-mono font-bold uppercase tracking-wider ${
            p.destacado
              ? 'bg-amber text-zinc-900'
              : 'bg-zinc-700/80 text-zinc-300'
          }`}>
            {p.nombre}
          </div>
          {p.destacado && (
            <div class="absolute top-0 right-0 px-3 py-1.5 rounded-tr-xl rounded-bl-lg text-[10px] font-mono font-bold uppercase whitespace-nowrap bg-gradient-to-r from-amber to-amber-dark text-zinc-900">
              ★ MÁS POPULAR
            </div>
          )}

          <div class="mt-8 mb-1 label-tag text-zinc-500">{p.etiqueta}</div>

          <div class="flex items-baseline gap-1 mt-2 mb-2">
            <span class={`nums font-extrabold text-4xl lg:text-5xl ${p.destacado ? 'text-amber' : 'text-zinc-100'}`}>{p.precio}</span>
            <span class={`text-base font-medium ${p.destacado ? 'text-zinc-400' : 'text-zinc-500'}`}>{p.periodo}</span>
          </div>

          {p.nota && (
            <div class={`text-xs font-mono mt-1 ${p.destacado ? 'text-amber/80' : 'text-zinc-500'}`}>{p.nota}</div>
          )}

          <div class={`my-5 h-px ${p.destacado ? 'bg-zinc-800' : 'bg-zinc-800/50'}`}></div>

          <ul class="space-y-3 flex-1">
            {p.caracteristicas.map((c) => (
              <li class="flex items-start gap-2 text-sm text-zinc-300">
                <Check size={14} class={`shrink-0 mt-0.5 ${p.destacado ? 'text-amber' : 'text-amber/60'}`} />
                <span>{c}</span>
              </li>
            ))}
          </ul>

          <a
            href={waUrl(`Hola quiero el plan ${p.nombre}`)}
            target="_blank"
            class={`mt-6 inline-flex items-center justify-center gap-2 px-5 py-3 rounded-lg font-medium text-sm transition-all ${
              p.destacado
                ? 'text-zinc-900 font-semibold'
                : 'bg-zinc-800/50 border border-zinc-700 text-zinc-300 hover:bg-zinc-800 hover:border-zinc-600'
            }`}
            style={p.destacado ? 'background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);' : ''}
          >
            {p.cta}
          </a>
        </div>
      ))}
    </div>

    <p class="gsap-fade-up mt-10 text-center text-sm text-zinc-500 font-mono">
      Sin tarjeta de crédito • Cancela cuando quieras • Tus datos siempre seguros
    </p>
  </div>
</section>
