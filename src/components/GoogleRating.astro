---
const rating = 5.0;
const totalReviews = 4;
const businessName = "TiendaPOS - Sistema Punto de Venta";
const googleUrl = "https://maps.app.goo.gl/KxyVyUBwn8qBSQ8F6";
const reviewUrl = "https://search.google.com/local/writereview?placeid=";
const stars = Array.from({ length: 5 }, (_, i) => i < Math.round(rating));
---

<a
  href={googleUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-20 sm:bottom-24 left-3 sm:left-4 md:left-6 z-30 flex items-center gap-2 sm:gap-3 px-3 sm:px-4 py-2 sm:py-2.5 rounded-xl bg-zinc-900/90 border border-zinc-700/60 hover:border-amber/30 shadow-lg shadow-black/30 backdrop-blur-md transition-all duration-300 hover:scale-105 hover:shadow-xl no-underline"
>
  <div class="flex items-center gap-1 shrink-0">
    <svg viewBox="0 0 48 48" class="w-5 h-5 sm:w-6 sm:h-6">
      <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/>
      <path fill="#FF3D00" d="m6.306 14.691 6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/>
      <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/>
      <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/>
    </svg>
  </div>
  <div class="flex flex-col leading-tight">
    <div class="flex items-center gap-1">
      <span class="text-amber text-xs sm:text-sm font-bold font-mono">{rating.toFixed(1)}</span>
      <span class="text-amber text-[10px] sm:text-xs leading-none">
        {stars.map((filled) =>
          filled
            ? "★"
            : "☆"
        ).join("")}
      </span>
    </div>
    <span class="text-zinc-100 text-[10px] sm:text-xs font-body font-medium whitespace-nowrap">
      {totalReviews} {totalReviews === 1 ? "reseña" : "reseñas"} en Google
    </span>
  </div>
</a>
