---
import { paises } from "../data/content";
import { Check, Globe, MapPin, Banknote, FileBadge } from "lucide-astro";
---

<section id="paises" class="relative overflow-hidden py-20 lg:py-28 bg-dark-tertiary">
  <!-- Background -->
  <div class="absolute inset-0 grid-pattern opacity-20 pointer-events-none" />
  <div class="absolute top-1/3 -right-10 w-96 h-96 bg-amber/10 rounded-full blur-[100px] pointer-events-none" />
  <div class="absolute bottom-0 right-1/4 w-72 h-72 bg-amber/5 rounded-full blur-[80px] pointer-events-none" />

  <div class="container-main relative">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <!-- Copy -->
      <div>
        <h2 class="gsap-fade-up text-zinc-100">
          Adaptamos la facturación, impuestos<br />
          <span class="text-amber">y monedas a la normativa de cada país.</span>
        </h2>

        <div class="gsap-stagger grid sm:grid-cols-3 gap-4 mt-8">
          <div class="p-5 rounded-xl bg-zinc-900/60 border border-zinc-800/60 text-center hover:border-amber/30 transition-all duration-300">
            <div class="w-10 h-10 rounded-full bg-amber/10 border border-amber/30 flex items-center justify-center mx-auto mb-3">
              <Globe size={18} class="text-amber" />
            </div>
            <div class="nums font-bold text-amber text-3xl mb-1">9</div>
            <div class="label-tag text-zinc-500 text-[10px]">PAÍSES ACTIVOS</div>
          </div>
          <div class="p-5 rounded-xl bg-zinc-900/60 border border-zinc-800/60 text-center hover:border-amber/30 transition-all duration-300">
            <div class="w-10 h-10 rounded-full bg-amber/10 border border-amber/30 flex items-center justify-center mx-auto mb-3">
              <Banknote size={18} class="text-amber" />
            </div>
            <div class="nums font-bold text-amber text-3xl mb-1">9</div>
            <div class="label-tag text-zinc-500 text-[10px]">MONEDAS LATAM</div>
          </div>
          <div class="p-5 rounded-xl bg-zinc-900/60 border border-zinc-800/60 text-center hover:border-amber/30 transition-all duration-300">
            <div class="w-10 h-10 rounded-full bg-amber/10 border border-amber/30 flex items-center justify-center mx-auto mb-3">
              <FileBadge size={18} class="text-amber" />
            </div>
            <div class="nums font-bold text-amber text-3xl mb-1">6</div>
            <div class="label-tag text-zinc-500 text-[10px]">IDs FISCALES</div>
          </div>
        </div>

        <!-- Footer note -->
        <div class="gsap-fade-up mt-8 flex flex-wrap gap-5 text-sm text-zinc-500 font-mono">
          {["Normativa sincronizada", "Todos configurados", "Datos fiscales reales"].map((t) => (
            <div class="flex items-center gap-2">
              <Check size={14} class="text-amber" />
              <span>{t}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Countries table -->
      <div class="gsap-scale-in overflow-x-auto rounded-xl bg-zinc-900/60 border border-zinc-800/60 shadow-lg">
        <div class="min-w-[520px]">
          <!-- Header -->
          <div class="grid grid-cols-[1.5fr_1fr_1fr_1.2fr_1.3fr] bg-zinc-800/50 border-b border-zinc-700/50">
            <div class="px-4 py-2.5 label-tag text-zinc-400 text-[10px]">PAÍS</div>
            <div class="px-4 py-2.5 label-tag text-zinc-400 text-[10px]">MONEDA</div>
            <div class="px-4 py-2.5 label-tag text-zinc-400 text-[10px]">ID FISCAL</div>
            <div class="px-4 py-2.5 label-tag text-zinc-400 text-[10px]">IMPUESTO</div>
            <div class="px-4 py-2.5 label-tag text-zinc-400 text-[10px]">ENTE</div>
          </div>

          <!-- Rows -->
          {paises.map((p, i) => (
            <div class={`grid grid-cols-[1.5fr_1fr_1fr_1.2fr_1.3fr] ${i < paises.length - 1 ? 'border-b border-zinc-800/30' : ''} hover:bg-amber/5 hover:border-l-2 hover:border-l-amber transition-all duration-200`}>
              <div class="px-4 py-3 text-zinc-100 text-sm font-medium">
                {p.nombre}
              </div>
              <div class="px-4 py-3 nums text-amber text-sm font-bold">{p.moneda}</div>
              <div class="px-4 py-3">
                <span class="inline-block px-2 py-0.5 rounded-md bg-zinc-800/80 text-zinc-300 text-[10px] font-mono font-semibold border border-zinc-700/50">
                  {p.id}
                </span>
              </div>
              <div class="px-4 py-3 text-zinc-300 text-sm font-medium">{p.impuesto}</div>
              <div class="px-4 py-3 text-zinc-400 text-xs font-mono">{p.ente}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
