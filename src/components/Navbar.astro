---
import { nav, site } from "../data/content";
import { Menu, X, ChevronDown } from "lucide-astro";
import { FaWhatsapp } from "react-icons/fa";
import { waUrl } from "../data/whatsapp";
---

  <header
    id="navbar"
    class="fixed top-0 left-0 right-0 z-50 bg-zinc-950 backdrop-blur-xl shadow-lg shadow-black/30 transition-all duration-500"
    data-navbar
  >
  <div class="container-main">
    <div
      class="flex items-center justify-between py-4 lg:py-5 transition-all duration-500 ease-out"
      data-navbar-inner
    >
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <img src="/assets/TiendaPoslogo1.png" alt="TiendaPOS" width="300" height="300" class="h-[72px] w-auto transition-all duration-500 ease-out" data-navbar-logo />
        <span class="font-display font-bold text-xl text-zinc-100 tracking-tight leading-none flex items-center transition-all duration-500 ease-out" data-navbar-title>
          {site.name}
        </span>
      </a>

      <!-- Nav desktop with dropdown -->
      <nav class="hidden lg:flex items-center gap-1">
        {nav.slice(0, 4).map((item) => (
          <a
            href={item.href}
            class="relative px-4 py-2 text-sm text-zinc-400 hover:text-zinc-100 transition-all duration-300 ease-out group"
          >
            {item.label}
            <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-amber rounded-full transition-all duration-300 ease-out group-hover:w-6" />
          </a>
        ))}

        <!-- More dropdown -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-4 py-2 text-sm text-zinc-400 hover:text-zinc-100 transition-colors duration-300">
            Más
            <ChevronDown size={14} class="transition-transform duration-300 ease-out group-hover:rotate-180" />
          </button>
          <div class="absolute top-full left-0 mt-1 py-2 w-48 bg-zinc-900/95 backdrop-blur-xl border border-zinc-800 rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 ease-out shadow-xl">
            {nav.slice(4).map((item) => (
              <a
                href={item.href}
                class="block px-4 py-2 text-sm text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/50 transition-colors duration-200"
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      </nav>

      <!-- CTA desktop -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href={waUrl("Hola quiero información desde el Navbar")}
          target="_blank"
          class="group inline-flex items-center gap-2.5 px-5 py-2.5 rounded-lg border border-amber/30 text-amber font-semibold text-sm transition-all duration-300 hover:bg-amber/10 hover:border-amber/50"
        >
          <FaWhatsapp size={18} />
          Escríbenos
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        class="lg:hidden relative flex items-center justify-center w-11 h-11 rounded-lg bg-zinc-800/50 border border-zinc-700 text-zinc-100 hover:bg-zinc-800 hover:border-zinc-600 transition-all duration-300"
        aria-label="Abrir menú"
        data-menu-toggle
      >
        <Menu size={20} data-icon-open class="transition-all duration-300 ease-out" />
        <X size={20} class="absolute transition-all duration-300 ease-out opacity-0 scale-75" data-icon-close />
      </button>
    </div>
  </div>
</header>

<!-- Mobile menu overlay (must be outside header to escape backdrop-blur stacking context) -->
<div
  id="mobile-menu"
  class="lg:hidden fixed inset-0 z-[60] text-zinc-100"
  style="background: #09090b; opacity: 0; transform: scale(0.95); pointer-events: none; transition: opacity 0.5s ease-out, transform 0.5s ease-out;"
  data-mobile-menu
>
  <div class="flex flex-col h-full px-6 py-6">
    <!-- Top: Title + Close -->
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2">
        <img src="/assets/TiendaPoslogo1.png" alt="TiendaPOS" width="96" height="96" class="h-9 w-auto" />
        <span class="font-display font-bold text-xl text-zinc-100">{site.name}</span>
      </div>
      <button
        id="close-menu-btn"
        class="flex items-center justify-center w-11 h-11 rounded-lg text-zinc-500 hover:text-zinc-100 transition-all duration-300"
        aria-label="Cerrar menú"
      >
        <X size={24} />
      </button>
    </div>

    <!-- Nav items centered -->
    <nav class="flex flex-col items-center gap-1 flex-1 justify-center">
      {nav.map((item, i) => (
        <a
          href={item.href}
          class="py-3 px-6 text-zinc-300 font-display font-semibold text-2xl hover:text-amber transition-all duration-300"
          data-mobile-link
          style={`transition-delay: ${i * 60}ms`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- WhatsApp -->
    <div class="flex justify-center pb-6">
      <a
        href={waUrl("Hola quiero información desde el menu movil")}
        target="_blank"
        class="flex items-center gap-2.5 px-5 py-3 rounded-xl bg-amber text-zinc-900 font-semibold transition-all duration-300 hover:bg-amber/90"
        data-mobile-link
      >
        <FaWhatsapp size={20} />
        Escríbenos por WhatsApp
      </a>
    </div>
  </div>
</div>

<script>
  const navbar = document.querySelector("[data-navbar]");
  const inner = document.querySelector("[data-navbar-inner]");
  const toggle = document.querySelector("[data-menu-toggle]");
  const menu = document.querySelector("[data-mobile-menu]");
  const iconOpen = document.querySelector("[data-icon-open]");
  const iconClose = document.querySelector("[data-icon-close]");
  const closeBtn = document.querySelector("#close-menu-btn");
  const mobileLinks = document.querySelectorAll("[data-mobile-link]");
  const logo = document.querySelector("[data-navbar-logo]");
  const title = document.querySelector("[data-navbar-title]");

  // Scroll behavior: shrink navbar + logo
  let scrolled = false;
  const onScroll = () => {
    const y = window.scrollY;
    if (y > 30 && !scrolled) {
      scrolled = true;
      inner?.classList.add("py-3");
      inner?.classList.remove("py-4", "lg:py-5");
      logo?.classList.add("h-12");
      logo?.classList.remove("h-[72px]");
      title?.classList.add("text-lg");
      title?.classList.remove("text-xl");
    } else if (y <= 30 && scrolled) {
      scrolled = false;
      inner?.classList.add("py-4", "lg:py-5");
      inner?.classList.remove("py-3");
      logo?.classList.add("h-[72px]");
      logo?.classList.remove("h-12");
      title?.classList.add("text-xl");
      title?.classList.remove("text-lg");
    }
  };
  window.addEventListener("scroll", onScroll, { passive: true });

  // Mobile menu toggle
  let menuOpen = false;
  const openMenu = () => {
    menuOpen = true;
    if (menu) {
      menu.style.opacity = "1";
      menu.style.transform = "scale(1)";
      menu.style.pointerEvents = "auto";
    }
    iconOpen?.classList.add("opacity-0", "scale-75", "rotate-90");
    iconOpen?.classList.remove("opacity-100", "scale-100", "rotate-0");
    iconClose?.classList.remove("opacity-0", "scale-75");
    iconClose?.classList.add("opacity-100", "scale-100");
    document.body.style.overflow = "hidden";
  };
  const closeMenu = () => {
    menuOpen = false;
    if (menu) {
      menu.style.opacity = "0";
      menu.style.transform = "scale(0.95)";
      menu.style.pointerEvents = "none";
    }
    iconOpen?.classList.remove("opacity-0", "scale-75", "rotate-90");
    iconOpen?.classList.add("opacity-100", "scale-100", "rotate-0");
    iconClose?.classList.add("opacity-0", "scale-75");
    iconClose?.classList.remove("opacity-100", "scale-100");
    document.body.style.overflow = "";
  };

  toggle?.addEventListener("click", () => {
    menuOpen ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener("click", closeMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Close on escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menuOpen) closeMenu();
  });
</script>
