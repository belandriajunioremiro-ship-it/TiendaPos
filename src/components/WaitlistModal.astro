---

<dialog
  id="waitlist-modal"
  class="fixed inset-0 z-50 m-auto h-fit max-h-[90vh] w-[92%] max-w-md rounded-2xl border border-zinc-700/50 bg-zinc-900/95 p-0 shadow-2xl shadow-black/50 backdrop:bg-black/60 backdrop:backdrop-blur-sm open:flex open:flex-col [&::backdrop]:bg-black/60 [&::backdrop]:backdrop-blur-sm"
  style="display: none;"
>
  <div class="relative overflow-hidden rounded-2xl">
    <div class="absolute inset-0 bg-gradient-to-br from-amber/10 via-transparent to-purple-500/10 pointer-events-none" />
    <div class="absolute -top-20 -right-20 w-40 h-40 bg-amber/20 rounded-full blur-[60px] pointer-events-none" />
    <div class="absolute -bottom-20 -left-20 w-40 h-40 bg-purple-500/20 rounded-full blur-[60px] pointer-events-none" />

    <button
      id="waitlist-close"
      class="absolute top-3 right-3 z-10 w-8 h-8 rounded-full bg-zinc-800/80 hover:bg-zinc-700 flex items-center justify-center text-zinc-400 hover:text-zinc-100 transition-all border border-zinc-700/50"
      aria-label="Cerrar"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="relative p-6 sm:p-8 flex flex-col items-center text-center">
      <div class="w-14 h-14 rounded-full bg-gradient-to-br from-amber to-amber-dark flex items-center justify-center mb-4 shadow-lg shadow-amber/20">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0A0A0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </div>

      <h2 class="text-xl sm:text-2xl font-display font-bold text-zinc-100 mb-2">
        ¡Estamos construyendo la app perfecta para tu negocio!
      </h2>
      <p class="text-sm sm:text-base text-zinc-400 mb-6 max-w-sm leading-relaxed">
        Gracias por visitarnos. TiendaPOS está en su fase final de desarrollo. No te quedes con la duda, escríbenos y te contamos cómo adelantarte.
      </p>

      <a
        href="https://wa.me/584247253544?text=Hola%20TiendaPOS!%20Vengo%20desde%20la%20web%20y%20quiero%20saber%20m%C3%A1s%20sobre%20la%20app."
        target="_blank"
        rel="noopener noreferrer"
        class="w-full inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm transition-all duration-300"
        style="background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); color: #0A0A0B;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span>Chatear por WhatsApp</span>
      </a>
    </div>
  </div>
</dialog>

<script>
  const MODAL_DELAY = 10000;
  const MODAL_COOKIE = "waitlist_shown";

  const dialog = document.getElementById("waitlist-modal") as HTMLDialogElement;
  const closeBtn = document.getElementById("waitlist-close");

  function getCookie(name: string): string | null {
    const match = document.cookie.match(new RegExp(`(^| )${name}=([^;]+)`));
    return match ? decodeURIComponent(match[2]) : null;
  }

  function setCookie(name: string, value: string, days: number) {
    const d = new Date();
    d.setTime(d.getTime() + days * 24 * 60 * 60 * 1000);
    document.cookie = `${name}=${encodeURIComponent(value)};expires=${d.toUTCString()};path=/;SameSite=Lax`;
  }

  function showModal() {
    if (!dialog) return;
    if (getCookie(MODAL_COOKIE) === "true") return;
    dialog.style.display = "flex";
    dialog.showModal();
    setCookie(MODAL_COOKIE, "true", 7);
  }

  function closeModal() {
    if (!dialog) return;
    dialog.style.display = "none";
    dialog.close();
  }

  setTimeout(showModal, MODAL_DELAY);

  closeBtn?.addEventListener("click", closeModal);

  dialog?.addEventListener("click", (e) => {
    const rect = dialog.getBoundingClientRect();
    const isOutside = e.clientX < rect.left || e.clientX > rect.right || e.clientY < rect.top || e.clientY > rect.bottom;
    if (isOutside) closeModal();
  });

  dialog?.addEventListener("cancel", (e) => {
    e.preventDefault();
    closeModal();
  });
</script>
