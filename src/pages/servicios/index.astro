---
import Base from "../../layouts/Base.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { servicios } from "../../data/servicios";
import { site } from "../../data/content";
import { waUrl } from "../../data/whatsapp";
import { ArrowRight, Check } from "lucide-astro";
---

<Base title={`Servicios — ${site.name}`} description="Sistema POS para farmacias, abastos, ferreterías, licorerías y mini markets en 9 países LATAM. Multi-moneda, IGTF automático y control de inventario.">
  <Navbar />
  <main>
    <section class="relative overflow-hidden pt-32 sm:pt-36 lg:pt-44 pb-16 sm:pb-20 bg-dark-primary">
      <div class="absolute inset-0 grid-pattern opacity-20 pointer-events-none" />
      <div class="absolute top-1/3 -right-32 w-96 h-96 bg-amber/10 rounded-full blur-[100px] pointer-events-none" />
      <div class="container-main relative">
        <div class="max-w-3xl">
          <h1 class="text-zinc-100 text-[2rem] sm:text-[2.5rem] md:text-[3.5rem] font-display font-black leading-[1.1] mb-4">
            Soluciones POS para <span class="text-amber">cada tipo de negocio</span>
          </h1>
          <p class="text-lg sm:text-xl text-zinc-400 max-w-2xl leading-relaxed">
            Farmacias, abastos, ferreterías, licorerías o mini markets. TiendaPOS se adapta a tu rubro, no al revés. Elegí el tuyo y empezá hoy.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16 lg:py-20 bg-dark-secondary">
      <div class="container-main">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {servicios.map((s) => (
            <a href={`/servicios/${s.slug}`} class="group p-6 rounded-xl bg-zinc-900/60 border border-zinc-800/60 hover:border-amber/30 transition-all">
              <h2 class="text-xl font-display font-bold text-zinc-100 group-hover:text-amber transition-colors mb-2">{s.titulo}</h2>
              <p class="text-zinc-400 text-sm leading-relaxed mb-4">{s.descripcion}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {s.caracteristicas.slice(0, 3).map((c) => (
                  <span class="inline-flex items-center gap-1 text-[10px] font-mono text-zinc-500 bg-zinc-800/50 px-2 py-1 rounded">
                    <Check size={10} class="text-amber" />
                    {c}
                  </span>
                ))}
              </div>
              <span class="inline-flex items-center gap-1 text-amber text-sm font-medium group-hover:gap-2 transition-all">
                Ver más <ArrowRight size={14} />
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
