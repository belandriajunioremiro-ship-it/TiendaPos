---
import Base from "../layouts/Base.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Onboarding from "../components/Onboarding.astro";
import MultiTenant from "../components/MultiTenant.astro";
import MultiMoneda from "../components/MultiMoneda.astro";
import Facturacion from "../components/Facturacion.astro";
import Caracteristicas from "../components/Caracteristicas.astro";
import ApiSection from "../components/ApiSection.astro";
import Paises from "../components/Paises.astro";
import Pricing from "../components/Pricing.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import Ticker from "../components/Ticker.astro";
import TrialBar from "../components/TrialBar.astro";
import Negocios from "../components/Negocios.astro";
import { faq } from "../data/content";

const faqLd = [{
  "@type": "FAQPage",
  name: "Preguntas frecuentes — TiendaPOS",
  mainEntity: faq.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
}];
---

<Base title="TiendaPOS | Sistema POS Multi-País para Latinoamérica" description="Sistema de punto de venta para farmacias, abastos y ferreterías en 9 países LATAM. Multi-moneda, IGTF automático, inventario y créditos. Probá 14 días gratis." ldExtra={faqLd}>
  <Navbar />
  <main>
    <Hero />
    <TrialBar />
    <Onboarding />
    <Negocios />
    <MultiTenant />
    <MultiMoneda />
    <Facturacion />
    <Caracteristicas />
    <ApiSection />
    <Paises />
    <Pricing />
    <FAQ />
    <CTA />
  </main>
  <Ticker />
  <Footer />
</Base>
