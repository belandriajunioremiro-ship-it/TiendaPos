---
import Base from "../layouts/Base.astro";
import Navbar from "../components/Navbar.astro";
import RateCalculator from "../components/RateCalculator";
import Footer from "../components/Footer.astro";

const ldExtra = [
  {
    "@type": "ListItem", position: 2, name: "Simulá tu venta", item: "https://tiendapos-app.vercel.app/simula-tu-venta/",
  },
  {
    "@type": "WebApplication",
    name: "Calculadora de margen de venta — TiendaPOS",
    description: "Calculá al instante tu margen de ganancia en USD con tasas de cambio actualizadas automáticamente. Dos monedas independientes, modo margen y modo precio.",
    applicationCategory: "FinanceApplication",
    operatingSystem: "Web",
    browserRequirements: "Requiere JavaScript",
  },
];
---

<Base title="Calculadora de Margen de Venta | TiendaPOS" description="Calculá tu margen de ganancia con tasas de cambio reales. Dos monedas independientes, modo margen o precio fijo. Ideal para importadores y comercios LATAM." ldExtra={ldExtra}>
  <Navbar />
  <main>
    <RateCalculator client:visible />
  </main>
  <Footer />
</Base>
